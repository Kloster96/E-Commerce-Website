{
  "name": "sneaker-vault-backend",
  "version": "1.0.0",
  "description": "Sneaker Vault API - Clean Architecture",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "seed": "npx tsx src/seed.ts",
    "seed:products": "npx tsx src/seedProducts.ts",
    "seed:gallery": "npx tsx src/seedGallery.ts",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mercadopago": "^2.12.0",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
